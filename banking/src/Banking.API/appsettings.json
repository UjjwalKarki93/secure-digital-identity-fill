{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "BankingDb": "Host=localhost;Port=5432;Database=banking_db;Username=postgres;Password=postgres"
  },
  "Security": {
    "HmacSecretKey": "shared-hmac-secret-key-change-in-production"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*/api/verification/start",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*/api/identity/webhook",
        "Period": "1m",
        "Limit": 20
      }
    ]
  }
}
