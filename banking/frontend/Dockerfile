FROM node:20-alpine AS build
WORKDIR /app

COPY package.json ./
RUN npm install

COPY . .

ARG VITE_NAGARIK_APP_URL=http://localhost:3001
ENV VITE_BANKING_API_URL=
ENV VITE_SIGNALR_URL=
ENV VITE_NAGARIK_APP_URL=$VITE_NAGARIK_APP_URL

RUN npm run build

FROM nginx:alpine AS final
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
